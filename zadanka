#include <iostream>

using namespace std;

unsigned long long fibonacci(int n) {
    if (n <= 0) return 0;
    if (n == 1) return 1;
    return fibonacci(n - 1) + fibonacci(n - 2);
}

int main() {
    cout << "7. wyraz ciagu Fibonacciego to: " << fibonacci(7) << endl;
    
    return 0;
}



