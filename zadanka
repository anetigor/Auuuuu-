#include <iostream>
#include <vector>
#include <string>

using namespace std;

class Osoba {
public:
    string imie, nazwisko, adres;

    Osoba(string i, string n, string a) : imie(i), nazwisko(n), adres(a) {}

    void wypisz() const {
        cout << imie << " " << nazwisko << ", " << adres << "\n";
    }
};

void szukajPoImieniu(const vector<Osoba>& lista, string szukaneImie) {
    cout << "--- Wyniki dla imienia: " << szukaneImie << " ---\n";
    for (const auto& osoba : lista) {
        if (osoba.imie == szukaneImie) osoba.wypisz();
    }
}

void szukajPoNazwisku(const vector<Osoba>& lista, string szukaneNazwisko) {
    cout << "--- Wyniki dla nazwiska: " << szukaneNazwisko << " ---\n";
    for (const auto& osoba : lista) {
        if (osoba.nazwisko == szukaneNazwisko) osoba.wypisz();
    }
}

int main() {
    vector<Osoba> listaOsob = {
        Osoba("Jan", "Kowalski", "Warszawa"),
        Osoba("Anna", "Nowak", "Krakow"),
        Osoba("Jan", "Wisniewski", "Poznan")
    };

    szukajPoImieniu(listaOsob, "Jan");
    szukajPoNazwisku(listaOsob, "Nowak");

    return 0;
}
