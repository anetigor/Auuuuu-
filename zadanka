#include <iostream>

using namespace std;

double poleKola(double promien) {
    const double PI = 3.14159;
    return PI * promien * promien;
}

double poleTrojkata(double podstawa, double wysokosc) {
    return 0.5 * podstawa * wysokosc;
}

int main() {
    cout << "Pole kola o promieniu 5: " << poleKola(5) << endl;
    cout << "Pole trojkata (podstawa 4, wysokosc 5): " << poleTrojkata(4, 5) << endl;
    
    return 0;
}

