#include <iostream>

using namespace std;

unsigned long long silnia(int n) {
    if (n <= 1) return 1;
    return n * silnia(n - 1);
}

int main() {
    cout << "Silnia z 5 wynosi: " << silnia(5) << endl;
    
    return 0;
}

