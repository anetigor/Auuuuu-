#include <iostream>
#include <vector>

using namespace std;

class ProstyStos {
private:
    vector<int> elementy;

public:
    void dodaj(int wartosc) {
        elementy.push_back(wartosc);
    }

    void usun() {
        if (!elementy.empty()) {
            elementy.pop_back();
        } else {
            cout << "Stos jest pusty!\n";
        }
    }

    void pokazGore() {
        if (!elementy.empty()) {
            cout << "Na gorze stosu: " << elementy.back() << "\n";
        } else {
            cout << "Stos jest pusty!\n";
        }
    }
};

int main() {
    ProstyStos stos;
    
    stos.dodaj(10);
    stos.dodaj(20);
    stos.pokazGore(); // Wypisze 20
    
    stos.usun();
    stos.pokazGore(); // Wypisze 10

    return 0;
}



